{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "tail-maker-external",
  "version": "0.1.0",
  "identifier": "com.osu-mania.tail-maker-external",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "title": "osu!mania Tail Maker - 外部工具",
        "width": 860,
        "height": 780,
        "resizable": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ]
  }
}
